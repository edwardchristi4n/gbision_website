# Salin file ini ke .env dan isi nilainya

DATABASE_URL=sqlite:///./gbi_sion.db

# Generate dengan: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=ganti-dengan-random-string-minimal-32-karakter

SESSION_COOKIE_NAME=gbi_session
SESSION_TTL_MINUTES=15

ALLOWED_ORIGINS=http://localhost:5173
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=5

# Akun superadmin pertama (dipakai script init)
INIT_ADMIN_EMAIL=admin@gbision.org
INIT_ADMIN_PASSWORD=GantiPasswordIni123!
